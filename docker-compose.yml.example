services:
  web:
    image: ghcr.io/vistis/course-notes-rag:main
    restart: unless-stopped
    environment:
      - PYTHONUNBUFFERED=1
      - GOOGLE_API_KEY=${GOOGLE_API_KEY}
    ports:
      - 8501:8501
    dns:
      - 9.9.9.9
    volumes:
      - ./data:/app/data:z,ro
      - model:/app/model:z

volumes:
  model:
